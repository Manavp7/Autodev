# Frontend-only configuration.
# Copy to `.env` (untracked) and tweak for local development.

# Optional base URL for the in-memory mock client. Anything works — no real
# requests are issued; axios-mock-adapter intercepts every call.
VITE_API_URL=http://mock.local/api

# Set to `true` to enable the realtime/socket.io path. Default false uses a
# deterministic mock-tick simulation instead so the UI never depends on a
# running server.
VITE_REALTIME=false

# Show the demo credentials grid on the login screen during development.
VITE_DEMO_USERS=true
